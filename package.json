{
  "name": "flarecms-root",
  "version": "1.0.0",
  "description": "FlareCMS monorepo root — scripts for emulators and development",
  "private": true,
  "scripts": {
    "emulators": "firebase emulators:start",
    "emulators:export": "firebase emulators:export ./emulator-data",
    "emulators:import": "firebase emulators:start --import ./emulator-data",
    "seed": "node scripts/seed.js",
    "seed:production": "node scripts/seed.js --production",
    "inject:users": "node scripts/inject_prod_users.js",
    "functions:build": "cd functions && npm run build",
    "functions:watch": "cd functions && npm run watch",
    "web:dev": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "server:dev": "node server/index.js",
    "dev": "concurrently --names \"web,server\" --prefix-colors \"cyan,magenta\" \"npm run web:dev\" \"npm run server:dev\"",
    "deploy:rules": "firebase deploy --only firestore:rules,storage:rules",
    "deploy:cors": "firebase storage:cors:set firebase/cors.json",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:functions": "npm run functions:build && firebase deploy --only functions",
    "deploy:hosting": "npm run web:build && firebase deploy --only hosting",
    "deploy": "npm run functions:build && npm run web:build && firebase deploy"
  },
  "dependencies": {
    "express": "^5.0.1",
    "firebase-admin": "^12.0.0",
    "multer": "^2.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "firebase-tools": "^13.29.3"
  }
}
