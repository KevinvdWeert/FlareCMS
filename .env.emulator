# FlareCMS local emulator environment — used by `npm run emulators` from the repo root.
# The Firebase project ID here must match .firebaserc default project.
FIREBASE_PROJECT_ID=flarecms-dev

# Emulator ports (keep in sync with firebase.json)
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
FUNCTIONS_EMULATOR_HOST=localhost:5001
