# FlareCMS Frontend Environment Variables
# Copy this file to .env.local and fill in your Firebase project values.

# Firebase project configuration
# Get these from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Set to 'true' to connect all Firebase services to local emulators.
# RECOMMENDED for local development: run `npm run emulators` from the repo root,
# then set this to 'true' to avoid CORS errors from un-deployed functions and to
# develop without touching the production Firebase project.
# Set to 'false' (or remove) when deploying or testing against the real project.
VITE_USE_EMULATORS=true
