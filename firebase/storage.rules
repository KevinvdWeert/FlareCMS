rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuthenticated() && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'editor'
      );
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPageAuthor(pageId) {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/pages/$(pageId)).data.createdBy == request.auth.uid;
    }

    match /pages/{pageId}/{allPaths=**} {
      // Public can read images so they render on published pages
      allow read: if true;
      // Only the page author or an admin may write; enforce 5 MB size limit and image MIME types
      allow write: if (isPageAuthor(pageId) || isAdmin())
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
