rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------------
    // Helper functions
    // ---------------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function getRole(uid) {
      return userDocExists(uid)
        ? get(/databases/$(database)/documents/users/$(uid)).data.role
        : null;
    }

    function isAdmin() {
      return isAuthenticated() && getRole(request.auth.uid) == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && getRole(request.auth.uid) == 'editor';
    }

    function isStaff() {
      return isAdmin() || isEditor();
    }

    // ---------------------------------------------------------------------------
    // Pages Collection
    // ---------------------------------------------------------------------------
    match /pages/{pageId} {
      // Anyone can read published pages; staff can read all
      allow read: if resource.data.status == 'published' || isStaff();
      // Any staff can create a new page
      allow create: if isStaff();
      // Only the page author or an admin can update or delete the page
      allow update: if isStaff() && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isStaff() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ---------------------------------------------------------------------------
    // Users Collection
    // ---------------------------------------------------------------------------
    match /users/{userId} {
      // Users can always read their own profile document.
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Admins can read all user documents.
      allow read: if isAdmin();

      // Users can create/update their own non-role fields without elevating permissions.
      // Cloud Functions (admin SDK) bypass rules entirely for role changes.
      allow create: if isAdmin() || (
        isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role == 'user'
      );

      allow update: if isAdmin() || (
        isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role
      );

      // Admins can delete user docs
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // Images Collection (local-upload media metadata)
    // ---------------------------------------------------------------------------
    match /images/{imageId} {
      // Staff can read all images
      allow read: if isStaff();
      // Staff can create image records (written by the frontend after a local upload)
      allow create: if isStaff();
      // Only the image owner or an admin can update or delete
      allow update: if isStaff() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isStaff() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ---------------------------------------------------------------------------
    // Media Assets Collection (legacy — kept for backward compatibility)
    // ---------------------------------------------------------------------------
    match /mediaAssets/{assetId} {
      // Staff can read all assets
      allow read: if isStaff();
      // Assets are registered through Cloud Functions (admin SDK bypasses rules).
      // Allow direct client creation/update by asset owner or admin.
      allow create: if isStaff();
      allow update: if isStaff() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isStaff() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ---------------------------------------------------------------------------
    // Activity Log Collection (append-only from Cloud Functions)
    // ---------------------------------------------------------------------------
    match /activityLog/{entryId} {
      // Staff can read the activity log
      allow read: if isStaff();
      // Writes only from Cloud Functions (admin SDK) — deny all client writes
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // Invites Collection
    // ---------------------------------------------------------------------------
    match /invites/{inviteId} {
      // Admins can read all invites
      allow read: if isAdmin();
      // Invite creation and acceptance handled by Cloud Functions
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // Settings Collection (system config)
    // ---------------------------------------------------------------------------
    match /settings/{settingId} {
      // Public site needs selected settings documents for rendering.
      allow read: if settingId in ['general', 'header', 'footer', 'homepage', 'identity', 'contact'] || isAdmin();
      // Only admins (via Cloud Functions) may write settings.
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // Settings History Collection
    // ---------------------------------------------------------------------------
    match /settingsHistory/{settingType}/versions/{versionId} {
      // Editors/admins can read version history in admin settings pages.
      allow read: if isStaff();
      // Admin can create history entries for local bypass mode.
      allow create: if isAdmin();
      // History entries are immutable.
      allow update, delete: if false;
    }
  }
}
